{
  "name": "ssx",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d --build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "dev:full": "concurrently -n docker,tauri -c blue,green \"npm run docker:up\" \"npm run tauri dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "docker compose --profile e2e -f docker/docker-compose.yml run --rm --build e2e-runner",
    "e2e:wdio": "wdio run e2e/wdio.conf.ts",
    "e2e:shell": "docker compose --profile e2e -f docker/docker-compose.yml run --rm --build --entrypoint bash e2e-runner",
    "e2e:teardown": "docker compose --profile e2e -f docker/docker-compose.yml down -v"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-shell": "^2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.11.0",
    "open-color": "^1.9.1",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-resizable-panels": "^4.10.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/node": "^25.6.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6",
    "@wdio/cli": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "@wdio/types": "^9",
    "concurrently": "^9.2.1",
    "expect-webdriverio": "^5",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8",
    "vitest": "^4",
    "webdriverio": "^9"
  }
}
